-- Statement: SHOW PROFILE
-- Source: https://dev.mysql.com/doc/refman/8.0/en/show-profile.html

SHOW PROFILE [type [, type] ...]
    [FOR QUERY n]
    [LIMIT row_count [OFFSET offset]]

type: {
    ALL
  | BLOCK IO
  | CONTEXT SWITCHES
  | CPU
  | IPC
  | MEMORY
  | PAGE FAULTS
  | SOURCE
  | SWAPS
}
