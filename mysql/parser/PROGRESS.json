      "rules": [],
      "depends_on": [],
      "tests": []
    },
    {
      "id": 1,
      "name": "names",
      "file": "name.go",
      "status": "done",
      "description": "Identifiers, qualified names (db.table.col), backtick-quoted identifiers, variable refs (@user, @@system)",
      "rules": [
        "identifier", "qualified_name", "column_ref", "table_ref",
        "backtick_ident", "user_variable", "system_variable"
      ],
      "depends_on": [0],
      "tests": ["TestParseIdentifiers", "TestParseQualifiedNames", "TestParseVariableRefs"]
    },
