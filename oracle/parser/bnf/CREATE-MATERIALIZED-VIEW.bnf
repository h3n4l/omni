-- Statement: CREATE MATERIALIZED VIEW
-- Source: https://docs.oracle.com/en/database/oracle/oracle-database/26/sqlrf/CREATE-MATERIALIZED-VIEW.html

CREATE MATERIALIZED VIEW [ IF NOT EXISTS ]
    [ schema. ] materialized_view
    [ ( column_alias [ ENCRYPT encryption_spec ] [, column_alias [ ENCRYPT encryption_spec ] ]... ) ]
    [ OF object_type ]
    [ scoped_table_ref_constraint ]
    [ DEFAULT COLLATION collation_name ]
    [ ON PREBUILT TABLE [ { WITH REDUCED PRECISION | WITHOUT REDUCED PRECISION } ] ]
    [ physical_properties ]
    [ materialized_view_props ]
    [ create_mv_refresh ]
    [ evaluation_edition_clause ]
    [ { ENABLE | DISABLE } ON QUERY COMPUTATION ]
    [ query_rewrite_clause ]
    [ unusable_editions_clause ]
    AS subquery
    [ annotations_clause ]

scoped_table_ref_constraint:
    SCOPE FOR ( { REF ( column ) | column } ) IS [ schema. ] scope_table_name

physical_properties:
    [ deferred_segment_creation ]
    [ segment_attributes_clause ]
    [ table_compression ]
    [ inmemory_table_clause ]
    [ { heap_org_table_clause | index_org_table_clause } ]
    [ CLUSTER cluster_name ( column [, column ]... ) ]

deferred_segment_creation:
    SEGMENT CREATION { IMMEDIATE | DEFERRED }

segment_attributes_clause:
    [ PCTFREE integer ]
    [ PCTUSED integer ]
    [ INITRANS integer ]
    [ storage_clause ]
    [ TABLESPACE tablespace_name ]
    [ logging_clause ]

logging_clause:
    { LOGGING | NOLOGGING }

table_compression:
    { COMPRESS [ BASIC
               | FOR OLTP
               | FOR QUERY [ { LOW | HIGH } ]
               | FOR ARCHIVE [ { LOW | HIGH } ]
               ]
    | NOCOMPRESS
    }

inmemory_table_clause:
    { INMEMORY [ inmemory_attributes ] [ inmemory_column_clause [, inmemory_column_clause ]... ]
    | NO INMEMORY
    }

inmemory_attributes:
    [ inmemory_memcompress ]
    [ inmemory_priority ]
    [ inmemory_distribute ]
    [ inmemory_duplicate ]

inmemory_memcompress:
    MEMCOMPRESS FOR { DML | QUERY [ { LOW | HIGH } ] | CAPACITY [ { LOW | HIGH } ] }
    | NO MEMCOMPRESS

inmemory_priority:
    PRIORITY { NONE | LOW | MEDIUM | HIGH | CRITICAL }

inmemory_distribute:
    DISTRIBUTE [ { AUTO | BY ROWID RANGE | BY PARTITION | BY SUBPARTITION } ]

inmemory_duplicate:
    DUPLICATE [ ALL ]
    | NO DUPLICATE

inmemory_column_clause:
    ( column [, column ]... ) { INMEMORY [ inmemory_memcompress ] | NO INMEMORY }

heap_org_table_clause:
    [ { CACHE | NOCACHE } ]

index_org_table_clause:
    ORGANIZATION INDEX
    [ { COMPRESS [ integer ] | NOCOMPRESS } ]
    [ OVERFLOW [ segment_attributes_clause ] ]

materialized_view_props:
    [ column_properties ]
    [ table_partitioning_clauses ]
    [ { CACHE | NOCACHE } ]
    [ parallel_clause ]
    [ build_clause ]

parallel_clause:
    { NOPARALLEL | PARALLEL [ integer ] }

build_clause:
    BUILD { IMMEDIATE | DEFERRED }

create_mv_refresh:
    { REFRESH
        [ { FAST | COMPLETE | FORCE } ]
        [ { ON COMMIT | ON DEMAND | ON STATEMENT } ]
        [ START WITH date ]
        [ NEXT date ]
        [ { WITH PRIMARY KEY | WITH ROWID } ]
        [ USING DEFAULT [ MASTER | LOCAL ] ROLLBACK SEGMENT [ rollback_segment ] ]
        [ USING { TRUSTED | ENFORCED } CONSTRAINTS ]
    | NEVER REFRESH
    }

evaluation_edition_clause:
    EVALUATE USING { CURRENT EDITION | EDITION edition | NULL EDITION }

query_rewrite_clause:
    { ENABLE | DISABLE } QUERY REWRITE

unusable_editions_clause:
    UNUSABLE EDITIONS
    [ BEFORE { CURRENT EDITION | EDITION edition } ]
    [ BEGINNING WITH { CURRENT EDITION | EDITION edition | NULL EDITION } ]

annotations_clause:
    ANNOTATIONS ( { ADD | REPLACE } annotation_name [ annotation_value ]
                   [, { ADD | REPLACE } annotation_name [ annotation_value ] ]... )
