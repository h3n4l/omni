-- Statement: OPEN MASTER KEY
-- Grammar rule: openMasterKeyStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/open-master-key-transact-sql

-- From TSql170.g:
openMasterKeyStatement:
    MASTER KEY DECRYPTION BY PASSWORD EqualsSign stringLiteral
    ;

-- Note: The OPEN keyword is consumed by the parent dispatcher rule (openStatements).

-- From Microsoft docs:
OPEN MASTER KEY DECRYPTION BY PASSWORD = 'password'
