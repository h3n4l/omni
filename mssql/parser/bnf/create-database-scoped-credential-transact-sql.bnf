-- Statement: CREATE DATABASE SCOPED CREDENTIAL
-- Grammar rule: createDatabaseScopedCredentialStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/create-database-scoped-credential-transact-sql

-- From TSql170.g:
createDatabaseScopedCredentialStatement:
    tScoped:Identifier  -- must match 'SCOPED'
    credentialStatementBody[vResult]
    ;

-- Sub-rule: credentialStatementBody
credentialStatementBody [CredentialStatement vParent]:
    tCredential:Identifier identifier  -- 'CREDENTIAL' credential_name
    With Identity EqualsSign stringLiteral
    (Comma tSecret:Identifier EqualsSign stringLiteral)?  -- 'SECRET' = 'secret'
    ;

-- Note: The parent CREATE statement provides: CREATE DATABASE
-- So the full parse is: CREATE DATABASE SCOPED CREDENTIAL credential_name
--   WITH IDENTITY = 'identity_name' [, SECRET = 'secret']

-- From Microsoft docs:
-- CREATE DATABASE SCOPED CREDENTIAL credential_name
-- WITH IDENTITY = 'identity_name'
--     [ , SECRET = 'secret' ]
-- [ ; ]
