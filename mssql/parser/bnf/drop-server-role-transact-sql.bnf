-- Statement: DROP SERVER ROLE
-- Grammar rule: dropServerRoleStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/drop-server-role-transact-sql

-- From TSql170.g:
dropServerRoleStatement:
    tRole:Identifier vName=identifier
    ;
    -- Note: Called within DROP SERVER context. tRole must match "Role".
    -- identifier = role_name

-- From Microsoft docs:
DROP SERVER ROLE role_name
[ ; ]
