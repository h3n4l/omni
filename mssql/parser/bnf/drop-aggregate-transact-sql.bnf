-- Statement: DROP AGGREGATE
-- Grammar rule: dropAggregateStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/drop-aggregate-transact-sql

-- From TSql170.g:
dropAggregateStatement:
    Aggregate
    ( If Exists )?
    dropObjectList
    ;

dropObjectList:
    dropObject ( Comma dropObject )*
    ;

dropObject:
    schemaObjectThreePartName
    ;

-- From Microsoft docs:
DROP AGGREGATE [ IF EXISTS ] [ schema_name . ] aggregate_name
