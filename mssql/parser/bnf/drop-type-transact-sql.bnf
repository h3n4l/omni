-- Statement: DROP TYPE
-- Grammar rule: dropTypeStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/drop-type-transact-sql

-- From TSql170.g:
dropTypeStatement:
    DROP TYPE
    ( IF EXISTS )?
    schema_object_name
    ;

-- Sub-rules:
-- dropObject: schema_object_name = schemaObjectThreePartName
--   (with constraint: only two-part names allowed, i.e. [schema.]type_name)

-- From Microsoft docs:
DROP TYPE [ IF EXISTS ] [ schema_name. ] type_name [ ; ]
