-- Statement: DROP ASYMMETRIC KEY
-- Grammar rule: dropAsymmetricKeyStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/drop-asymmetric-key-transact-sql

-- From TSql170.g:
dropAsymmetricKeyStatement:
    DROP ASYMMETRIC KEY key_name
    removeProviderKeyOpt?
    ;

removeProviderKeyOpt:
    REMOVE PROVIDER KEY
    ;

-- From Microsoft docs:
DROP ASYMMETRIC KEY key_name [ REMOVE PROVIDER KEY ]
