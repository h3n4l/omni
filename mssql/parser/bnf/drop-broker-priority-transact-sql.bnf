-- Statement: DROP BROKER PRIORITY
-- Grammar rule: dropBrokerPriorityStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/drop-broker-priority-transact-sql

-- From TSql170.g:
-- Parent: DROP dispatches via {NextTokenMatches(CodeGenerationSupporter.Broker)}?

dropBrokerPriorityStatement:
    /* DROP */ BROKER PRIORITY identifier
    ;

-- Note: The rule is invoked after DROP has already been consumed.
-- 'Broker' is matched via Match(tBroker, CodeGenerationSupporter.Broker).
-- 'Priority' is matched via Match(tPriority, CodeGenerationSupporter.Priority).
-- identifier is the conversation priority name.

-- From Microsoft docs:
-- DROP BROKER PRIORITY ConversationPriorityName
-- [;]
