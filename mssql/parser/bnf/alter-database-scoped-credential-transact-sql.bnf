-- Statement: ALTER DATABASE SCOPED CREDENTIAL
-- Grammar rule: alterDatabaseScopedCredentialStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/alter-database-scoped-credential-transact-sql

-- From TSql170.g:

alterDatabaseScopedCredentialStatement:
    SCOPED
    credentialStatementBody
    ;

credentialStatementBody:
    CREDENTIAL identifier
    WITH IDENTITY EqualsSign stringLiteral
    ( Comma SECRET EqualsSign stringLiteral )?
    ;

-- From Microsoft docs:

ALTER DATABASE SCOPED CREDENTIAL credential_name WITH IDENTITY = 'identity_name'
    [ , SECRET = 'secret' ]
