-- Statement: DROP CREDENTIAL
-- Grammar rule: dropCredentialStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/drop-credential-transact-sql

-- From TSql170.g:
dropCredentialStatement:
    DROP CREDENTIAL credential_name
    ;

-- Also: dropDatabaseScopedCredentialStatement (for DATABASE SCOPED CREDENTIAL):
dropDatabaseScopedCredentialStatement:
    DROP DATABASE SCOPED CREDENTIAL credential_name
    ;

-- From Microsoft docs:
DROP CREDENTIAL credential_name
