-- Statement: ALTER SERVER CONFIGURATION
-- Grammar rule: alterServerConfigurationStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/alter-server-configuration-transact-sql

-- From TSql170.g:
alterServerConfigurationStatement:
    -- Context: ALTER SERVER already consumed
    CONFIGURATION SET
    (
        alterServerConfigurationSetProcessAffinityStatement
    |   alterServerConfigurationSetBufferPoolExtensionStatement
    |   alterServerConfigurationSetDiagnosticsLogStatement
    |   alterServerConfigurationSetFailoverClusterPropertyStatement
    |   alterServerConfigurationSetHadrClusterStatement
    |   alterServerConfigurationSetSoftNumaStatement
    |   alterServerConfigurationSetExternalAuthenticationStatement
    )
    ;

alterServerConfigurationSetProcessAffinityStatement:
    PROCESS AFFINITY
    tCpuOrNumanode EqualsSign
    (
        affinityRangeList                -- CPU = range or NUMANODE = range
    |   AUTO                             -- CPU = AUTO
    )
    ;

affinityRangeList:
    affinityRange (Comma affinityRange)*
    ;

affinityRange:
    integer (TO integer)?
    ;

alterServerConfigurationSetBufferPoolExtensionStatement:
    BUFFER POOL EXTENSION
    alterServerConfigurationBufferPoolExtensionContainerOption
    ;

alterServerConfigurationBufferPoolExtensionContainerOption:
    onOffOptionValue
    (
        LeftParenthesis
            alterServerConfigurationBufferPoolExtensionFileNameOption
            Comma alterServerConfigurationBufferPoolExtensionSizeOption
        RightParenthesis
    )?
    ;

alterServerConfigurationSetDiagnosticsLogStatement:
    DIAGNOSTICS LOG
    alterServerConfigurationDiagnosticsLogOption
    ;

alterServerConfigurationDiagnosticsLogOption:
    onOffOptionValue                                      -- ON | OFF
    | MAX_SIZE EqualsSign (integer MB | DEFAULT)           -- MAX_SIZE = n MB | DEFAULT
    | tLogOption EqualsSign                                -- PATH = 'path' | DEFAULT
        (stringOrDefaultLiteralOptionValue                 --   or MAX_FILES = integer | DEFAULT
        | integerOrDefaultLiteralOptionValue)
    ;

alterServerConfigurationSetFailoverClusterPropertyStatement:
    FAILOVER CLUSTER PROPERTY
    alterServerConfigurationFailoverClusterPropertyOption
    ;

alterServerConfigurationFailoverClusterPropertyOption:
    tProperty EqualsSign
    (
        binaryOrDefaultLiteralOptionValue          -- SqlDumperDumpFlags
    |   stringOrDefaultLiteralOptionValue           -- SqlDumperDumpPath
    |   integerOrDefaultLiteralOptionValue          -- VerboseLogging, etc.
    )
    ;

alterServerConfigurationSetHadrClusterStatement:
    HADR CLUSTER
    alterServerConfigurationHadrClusterOption
    ;

alterServerConfigurationHadrClusterOption:
    tOptionKind EqualsSign
    (
        stringLiteralOptionValue        -- 'remote_windows_cluster'
    |   LOCAL
    )
    ;

alterServerConfigurationSetSoftNumaStatement:
    SOFTNUMA
    onOffOptionValue
    ;

alterServerConfigurationSetExternalAuthenticationStatement:
    EXTERNAL AUTHENTICATION
    alterServerConfigurationExternalAuthenticationContainerOption
    ;

alterServerConfigurationExternalAuthenticationContainerOption:
    onOffOptionValue
    (
        LeftParenthesis alterServerConfigurationExternalAuthenticationOption RightParenthesis
    )?
    ;

alterServerConfigurationExternalAuthenticationOption:
    USE_IDENTITY
    | CREDENTIAL_NAME EqualsSign stringLiteralOptionValue
    ;

-- From Microsoft docs:
-- ALTER SERVER CONFIGURATION
-- SET <optionspec>
-- [;]
--
-- <optionspec> ::=
-- {
--      <process_affinity>
--    | <diagnostic_log>
--    | <failover_cluster_property>
--    | <hadr_cluster_context>
--    | <buffer_pool_extension>
--    | <soft_numa>
--    | <memory_optimized>
--    | <hardware_offload>
--    | <suspend_for_snapshot_backup>
-- }
--
-- <process_affinity> ::=
--    PROCESS AFFINITY
--    {
--      CPU = { AUTO | <CPU_range_spec> }
--    | NUMANODE = <NUMA_node_range_spec>
--    }
--    <CPU_range_spec> ::= { CPU_ID | CPU_ID TO CPU_ID } [ ,...n ]
--    <NUMA_node_range_spec> ::= { NUMA_node_ID | NUMA_node_ID TO NUMA_node_ID } [ ,...n ]
--
-- <diagnostic_log> ::=
--    DIAGNOSTICS LOG
--    { ON | OFF | PATH = { 'os_file_path' | DEFAULT }
--    | MAX_SIZE = { 'log_max_size' MB | DEFAULT }
--    | MAX_FILES = { 'max_file_count' | DEFAULT } }
--
-- <failover_cluster_property> ::=
--    FAILOVER CLUSTER PROPERTY <resource_property>
--    <resource_property> ::=
--    { VerboseLogging = { 'logging_detail' | DEFAULT }
--    | SqlDumperDumpFlags = { 'dump_file_type' | DEFAULT }
--    | SqlDumperDumpPath = { 'os_file_path'| DEFAULT }
--    | SqlDumperDumpTimeOut = { 'dump_time-out' | DEFAULT }
--    | FailureConditionLevel = { 'failure_condition_level' | DEFAULT }
--    | HealthCheckTimeout = { 'health_check_time-out' | DEFAULT } }
--
-- <hadr_cluster_context> ::=
--    HADR CLUSTER CONTEXT = { 'remote_windows_cluster' | LOCAL }
--
-- <buffer_pool_extension>::=
--    BUFFER POOL EXTENSION
--    { ON ( FILENAME = 'os_file_path_and_name' , SIZE = <size_spec> )
--    | OFF }
--    <size_spec> ::= { size [ KB | MB | GB ] }
--
-- <soft_numa> ::=
--    SOFTNUMA { ON | OFF }
