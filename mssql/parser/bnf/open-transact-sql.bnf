-- Statement: OPEN CURSOR
-- Grammar rule: openCursorStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/language-elements/open-transact-sql

-- From TSql170.g:
openCursorStatement:
    cursorId
    ;

cursorId:
    ( GLOBAL identifier )
    | identifierOrVariable
    ;

-- Note: The OPEN keyword is consumed by the parent dispatcher rule (openStatements),
-- which routes to openCursorStatement, openMasterKeyStatement, or openSymmetricKeyStatement.

-- From Microsoft docs:
OPEN { { [ GLOBAL ] cursor_name } | cursor_variable_name }
