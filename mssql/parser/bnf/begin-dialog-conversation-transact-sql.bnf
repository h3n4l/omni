-- Statement: BEGIN DIALOG
-- Grammar rule: beginDialogStatement (TSql170.g:26242)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/begin-dialog-conversation-transact-sql

-- From TSql170.g:
beginDialogStatement:
    Begin Identifier /* DIALOG */
    (Identifier /* CONVERSATION */)?
    variable
    From Identifier /* SERVICE */ identifierOrVariable
    To Identifier /* SERVICE */ stringOrVariable
    (Comma stringOrVariable)?       -- instance spec
    (On Identifier /* CONTRACT */ identifierOrVariable)?
    (With beginConversationArgument (Comma beginConversationArgument)*)?
    ;

beginConversationArgument:
    Identifier EqualsSign
    (
        scalarExpressionBeginDialogConversationArgument
        | onOffBeginDialogConversationArgument
    )
    ;

scalarExpressionBeginDialogConversationArgument:
    expression
    -- Options: RELATED_CONVERSATION, RELATED_CONVERSATION_GROUP, LIFETIME
    ;

onOffBeginDialogConversationArgument:
    (On | Off)
    -- Option: ENCRYPTION
    ;

