-- Statement: BACKUP SERVICE MASTER KEY
-- Grammar rule: backupServiceMasterKeyStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/backup-service-master-key-transact-sql

-- From TSql170.g:
backupServiceMasterKeyStatement:
    Identifier /* SERVICE */ backupMasterKeyBody
    ;

backupMasterKeyBody:
    Identifier /* MASTER */ Key To File EqualsSign stringLiteral
    Identifier /* ENCRYPTION */ By Identifier /* PASSWORD */ EqualsSign stringLiteral
    ;

-- Note: The leading BACKUP keyword is consumed by the parent backupStatements rule.

-- From Microsoft docs:
-- BACKUP SERVICE MASTER KEY TO FILE = 'path_to_file'
--     ENCRYPTION BY PASSWORD = 'password'
