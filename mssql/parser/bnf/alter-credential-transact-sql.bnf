-- Statement: ALTER CREDENTIAL
-- Grammar rule: alterCredentialStatement (TSql170.g)
-- Doc: https://learn.microsoft.com/en-us/sql/t-sql/statements/alter-credential-transact-sql

-- From TSql170.g:
alterCredentialStatement:
    credentialStatementBody[vResult]
    ;

credentialStatementBody[CredentialStatement vParent]:
    tCredential:Identifier identifier  // CREDENTIAL credential_name
    With Identity EqualsSign stringLiteral  // WITH IDENTITY = 'identity_name'
    (Comma tSecret:Identifier EqualsSign stringLiteral)?  // , SECRET = 'secret'
    ;

-- From Microsoft docs:
-- ALTER CREDENTIAL credential_name WITH IDENTITY = 'identity_name'
--     [ , SECRET = 'secret' ]
